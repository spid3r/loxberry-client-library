# Copy to `.env` and fill in. Never commit `.env`.
# Used by: `npm run test:live*` (repo loads this file in the live test only), MCP server env, CLI if you pass Node `--env-file=.env` or export these vars yourself.

# Required for live tests / remote use (no trailing slash). Must match what you type in the browser.
LOXBERRY_BASE_URL=https://loxberry.local

# If login fails with HTTP 404, set the path of the admin login page (from browser address bar, path only).
# LOXBERRY_LOGIN_PATH=/admin/index.php

# Rare: HTML form field names differ on your build (inspect the login form).
# LOXBERRY_LOGIN_USER_FIELD=user
# LOXBERRY_LOGIN_PASSWORD_FIELD=password

# Web admin user + password (used as HTTP Basic on /admin for stock LoxBerry)
LOXBERRY_USERNAME=
LOXBERRY_PASSWORD=

# SecurePIN for plugin install via plugininstall.cgi (live upload / MCP upload)
# LOXBERRY_SECURE_PIN=

# Stock LoxBerry = basic (default). Use `form` only for a custom HTML login flow.
# LOXBERRY_AUTH_STRATEGY=basic

# Optional: HTTP Basic Auth in front of /admin (Apache/nginx). Not the LoxBerry form — a browser popup or 401 before the HTML login page.
# LOXBERRY_HTTP_BASIC_USERNAME=
# LOXBERRY_HTTP_BASIC_PASSWORD=
# Or reuse web UI credentials for the Basic layer:
# LOXBERRY_HTTP_BASIC_SAME=1

# --- Live test options (optional; used only when you run `npm run test:live*`) ---
# Do NOT set LOXBERRY_LIVE_TESTS here — that flag is added by those npm scripts so `npm test` never hits your LoxBerry.
# You may set the upload/uninstall flags in `.env` if you prefer them over passing env on the command line:

# Set to 1 to upload test/fixtures/e2e-plugin (packed to zip in-memory) — installs a tiny placeholder plugin.
LOXBERRY_LIVE_UPLOAD=0

# DANGER: Set to 1 only on a dev LoxBerry you control. Removes ONLY the E2E plugin identified by folder + title check.
LOXBERRY_LIVE_UNINSTALL=0

# How long to poll for the plugin row after upload (ms). Mocha test timeout is derived from this + 60s headroom.
# LOXBERRY_LIVE_INSTALL_TIMEOUT_MS=120000

# Live tests: write tmp/loxberry-live-debug/ (upload-response.html, list-latest.html, trace.log) and echo step timings.
# Or run: npm run test:live:debug (upload only) / npm run test:live:debug:full (upload + uninstall + uninstall-response.html)
# LOXBERRY_LIVE_DEBUG=1

# Any use of the library: log plugin list/upload steps to stderr (no files).
# LOXBERRY_CLIENT_DEBUG=1

# Expected plugin folder/name in plugin.cfg (do not change unless you change the fixture).
LOXBERRY_E2E_PLUGIN_FOLDER=loxberryclie2e

# Exact TITLE in plugin.cfg — used as a safety check before uninstall.
LOXBERRY_E2E_PLUGIN_TITLE=E2E Client Lib
